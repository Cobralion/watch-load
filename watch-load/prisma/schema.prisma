generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------
// ---------- ENUMS ---------------
// --------------------------------

enum Role {
  ADMIN
  USER
}

enum Afib {
  NEGATIVE
  POSITIVE
  INCONCLUSIVE
  UNKNOWN
}

// --------------------------------
// ---------- MODELS --------------
// --------------------------------

model User {
  id       String           @id @default(cuid())
  username String           @unique
  password String
  role     Role
  name     String?
  devices  WithingsDevice[]
}

model WithingsDevice {
  id               String   @id @default(cuid())
  access_token     String
  refresh_token    String
  expires_at       DateTime
  withings_user_id String
  last_sync        DateTime @default("1970-01-01T00:00:00Z") // beginning of time

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model HeartMeasurement {
  id                 String   @id @default(cuid())
  signal_id          BigInt   @unique
  device_id          String
  heart_rate         Int
  afib               Afib
  timestamp          DateTime
  modified           DateTime
  signal             Int[]
  sampling_frequency Int

  trails Trails?

  @@index([signal_id, timestamp])
}

model Trails {
  id       String @id @default(cuid())
  trail_id String @unique

  heart_measurement_id String           @unique
  heart_measurement    HeartMeasurement @relation(fields: [heart_measurement_id], references: [id], onDelete: Cascade)
}
